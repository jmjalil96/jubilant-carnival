{
  "name": "jubilant-carnival",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "pnpm --parallel --stream --filter @jubilant-carnival/api --filter @jubilant-carnival/web dev",
    "dev:api": "pnpm --filter @jubilant-carnival/api dev",
    "dev:web": "pnpm --filter @jubilant-carnival/web dev",
    "typecheck": "pnpm --filter @jubilant-carnival/api typecheck && pnpm --filter @jubilant-carnival/web typecheck",
    "lint": "pnpm --filter @jubilant-carnival/api lint && pnpm --filter @jubilant-carnival/web lint",
    "lint:fix": "pnpm --filter @jubilant-carnival/api lint:fix && pnpm --filter @jubilant-carnival/web lint:fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "build": "pnpm --filter @jubilant-carnival/api build && pnpm --filter @jubilant-carnival/web build",
    "test": "pnpm --filter @jubilant-carnival/api test && pnpm --filter @jubilant-carnival/web test",
    "test:e2e": "pnpm --filter @jubilant-carnival/web test:e2e",
    "test:http": "pnpm --filter @jubilant-carnival/api test:http",
    "test:process": "pnpm --filter @jubilant-carnival/api test:process",
    "test:db": "pnpm --filter @jubilant-carnival/api test:db"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}

{
  "name": "@jubilant-carnival/contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "import": "./dist/auth.js"
    },
    "./system": {
      "types": "./src/system.ts",
      "import": "./dist/system.js"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "import": "./dist/errors.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:workspace": "pnpm run dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm exec eslint src",
    "lint:fix": "pnpm exec eslint src --fix",
    "format": "pnpm exec prettier --write src package.json tsconfig.json README.md",
    "format:check": "pnpm exec prettier --check src package.json tsconfig.json README.md"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  }
}
